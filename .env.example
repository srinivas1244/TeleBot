# ── Required ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── AI Report Provider (all free, no paid API) ────────────────────────────────
# Choose one: "none" | "ollama" | "groq"
#
#   none   → structured rule-based report, zero AI setup needed (default)
#
#   ollama → runs a local LLM on your machine, completely free
#            Install: https://ollama.com
#            Then run: ollama pull llama3.1
#            Then set: AI_PROVIDER=ollama
#
#   groq   → free cloud API, no credit card required
#            Get free key: https://console.groq.com
#            Then set: AI_PROVIDER=groq  and  GROQ_API_KEY=your_key
#
AI_PROVIDER=none

# Ollama settings (only needed if AI_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Groq settings (only needed if AI_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Optional ──────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to use the bot (empty = all users)
# Example: AUTHORIZED_USER_IDS=123456789,987654321
AUTHORIZED_USER_IDS=

# Rate limiting
MAX_SCANS_PER_USER_PER_HOUR=3
MAX_CONCURRENT_SCANS=5

# Timeouts (seconds)
PORT_SCAN_TIMEOUT=2.0
HTTP_TIMEOUT=12.0

# Output paths
DATABASE_PATH=storage/scans.db
REPORT_DIR=reports
